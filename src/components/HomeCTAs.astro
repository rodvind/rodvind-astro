<section class="home-ctas fade-section">
  <div class="home-ctas-inner">
    <a href="/resume" class="home-cta home-cta-primary">View full resume</a>
    <a href="/work" class="home-cta home-cta-secondary">See all work</a>
    <a href="mailto:hello@rodvin.com" class="home-cta home-cta-secondary">Get in touch</a>
  </div>
</section>

<style>
  .home-ctas {
    padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 5vw, 2rem);
    margin: 0;
    background-color: #0f172a;
    text-align: center;
  }
  .home-ctas-inner {
    max-width: 42rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .home-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .home-cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .home-cta-primary {
    background-color: #3b82f6;
    color: #fff;
  }
  .home-cta-secondary {
    background-color: transparent;
    color: #e2e8f0;
    border: 2px solid #475569;
  }
  .home-cta-secondary:hover {
    border-color: #94a3b8;
  }
</style>
